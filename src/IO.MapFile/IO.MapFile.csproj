<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);S1133</NoWarn>
    <EmitCompilerGeneratedFiles>True</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Builders\BuilderExtensions.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CodeOfChaos.Unions" VersionOverride="6.4.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Altemiq.Patterns.Builder.Generator">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CodeOfChaos.Unions.Generators">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Using Include="CodeOfChaos.Unions" />
    <Using Include="$(RootNamespace).Unions" />
    <Using Include="$(RootNamespace).Types" />
  </ItemGroup>

</Project>
